# Cuotas / edge — FASE 3, OPCIONAL.
# Si no defines nada, la app funciona igual SIN la columna de cuotas.
# Copia este archivo a `.env` (que está en .gitignore) y rellena tus valores.
# NUNCA se commitean claves.

# Clave de OddsPapi. Free tier: 250 req/mes, incluye Pinnacle. https://oddspapi.io
VITE_ODDS_API_KEY=

# Casa de apuestas a usar (por defecto: pinnacle)
VITE_ODDS_BOOKMAKER=pinnacle

# IDs de torneo del Mundial 2026 en OddsPapi (coma-separados).
# Consíguelos en su panel / documentación (https://oddspapi.io/en/docs).
VITE_ODDS_TOURNAMENT_IDS=

# Mapa JSON nombre-canónico -> participantId de OddsPapi, para emparejar de forma
# fiable (los partidos simultáneos no se distinguen solo por la hora).
# Ejemplo: {"Argentina":12,"France":7,"Brazil":3}
VITE_ODDS_TEAM_IDS=
